function setLang(l){
  state.lang=l;
  var t=T[l];
  var ids={
    'badge-txt':t.badge,'main-title':t.title,'main-sub':t.sub,'week-label':t.week,
    's0-title':t.s0,'l-bta':t.l_bta,'l-name':t.l_name,
    's1-title':t.s1,'l-days':t.l_days,'l-features':t.l_feat,
    's2-title':t.s2,'l-overall':t.l_overall,'l-recommend':t.l_rec,'nps-low':t.nps_low,'nps-high':t.nps_high,
    's3-title':t.s3,'l-crash':t.l_crash,'crash-none':t.crash_none,'crash-minor':t.crash_minor,'crash-major':t.crash_major,
    'l-bug-desc':t.l_bug,'l-lang-ok':t.l_lang_ok,'lang-ok-label':t.lang_ok_lbl,'l-lang-issue':t.l_lang_issue,
    's4-title':t.s4,'l-best':t.l_best,'l-worst':t.l_worst,'l-feature':t.l_feat_req,
    's5-title':t.s5,'l-ai-quality':t.l_ai,'l-ai-comment':t.l_ai_com,
    'submit-label':t.submit.replace(/^[^\s]+\s/,''),'submit-note':t.submit_note,'sending-label':t.sending,
    'success-h':t.success_h,'success-p':t.success_p
  };
  Object.keys(ids).forEach(function(id){
    var el=document.getElementById(id);
    if(el) el.textContent=ids[id];
  });
  if(state.overall) document.getElementById('star-overall-label').textContent=SL[l][state.overall];
  if(state.ai)      document.getElementById('star-ai-label').textContent=SL[l][state.ai];
  ['fr','en','de','es','it'].forEach(function(c){
    document.getElementById('btn-'+c).classList.toggle('active',c===l);
  });
  document.documentElement.lang=l;
}

var det=navigator.language.slice(0,2);
setLang(['fr','en','de','es','it'].includes(det)?det:'fr');
