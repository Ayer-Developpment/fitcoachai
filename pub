<script>
  // Pilote l'auto-scroll en fonction de la hauteur réelle du contenu.
  // Approche simple et robuste : on découpe le trajet total en segments
  // (un par section), chaque segment a un temps de "lecture" (lent/quasi figé)
  // suivi d'un temps de transition vers la section suivante.
  (function () {
    const reel = document.getElementById('reel');
    const sections = Array.from(reel.querySelectorAll('section'));

    const TOTAL_DURATION = 26000; // durée totale d'un cycle, en ms
    const READ_SHARE = 0.62;      // proportion du temps passée "à lire" (quasi figé) vs en transition

    let rafId = null;
    let cycleStart = null;
    let segments = []; // [{from, to, readMs, transMs}]

    // Sur Safari iOS, window.innerHeight peut être instable tant que la
    // barre d'adresse n'a pas fini de se replier/déplier. visualViewport.height
    // donne la hauteur réellement visible à l'instant T, plus fiable ici.
    function currentViewportHeight() {
      if (window.visualViewport && window.visualViewport.height) {
        return window.visualViewport.height;
      }
      return window.innerHeight;
    }

    function computeSegments() {
      const viewportH = currentViewportHeight();
      const dist = Math.max(0, reel.scrollHeight - viewportH);
      // Positions cibles : départ (0), puis le haut de chaque section suivante, puis la fin (dist)
      const tops = sections.map(s => Math.min(s.offsetTop, dist));
      const stops = [0, ...tops.slice(1), dist].filter((v, i, arr) => i === 0 || v > arr[i - 1]);
      if (stops[stops.length - 1] !== dist) stops.push(dist);

      const n = stops.length - 1;
      if (n <= 0) return [{ from: 0, to: 0, readMs: TOTAL_DURATION, transMs: 0 }];

      const perSegment = TOTAL_DURATION / n;
      const readMs = perSegment * READ_SHARE;
      const transMs = perSegment - readMs;

      const segs = [];
      for (let i = 0; i < n; i++) {
        segs.push({ from: stops[i], to: stops[i + 1], readMs, transMs });
      }
      return segs;
    }

    function easeInOut(p) {
      return p < 0.5 ? 2 * p * p : 1 - Math.pow(-2 * p + 2, 2) / 2;
    }

    function frame(ts) {
      if (cycleStart === null) cycleStart = ts;
      let elapsed = ts - cycleStart;

      // Trouve dans quel segment on se trouve
      let acc = 0;
      let y = 0;
      for (const seg of segments) {
        const segTotal = seg.readMs + seg.transMs;
        if (elapsed <= acc + segTotal || seg === segments[segments.length - 1]) {
          const local = elapsed - acc;
          if (local <= seg.readMs) {
            y = seg.from; // phase de lecture : reste sur place
          } else {
            const p = Math.min(1, (local - seg.readMs) / Math.max(1, seg.transMs));
            y = seg.from + (seg.to - seg.from) * easeInOut(p);
          }
          break;
        }
        acc += segTotal;
      }

      reel.style.transform = `translateY(${-y}px)`;

      if (elapsed >= TOTAL_DURATION) {
        cycleStart = ts; // boucle
      }
      rafId = requestAnimationFrame(frame);
    }

    function recompute() {
      // Recalcule les segments sans casser la progression en cours :
      // on garde le cycle en cours, seules les bornes from/to changent
      // (utile quand Safari finit de replier sa barre d'adresse après coup).
      segments = computeSegments();
    }

    function start() {
      segments = computeSegments();
      cycleStart = null;
      if (rafId) cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(frame);
    }

    // On attend que les polices/images soient chargées ET qu'on ait laissé
    // deux frames s'écouler, pour que Safari ait fini de stabiliser sa UI
    // (barre d'adresse) avant de mesurer le viewport une première fois.
    function waitStableThenStart() {
      requestAnimationFrame(() => requestAnimationFrame(() => {
        start();
        // Une resynchro de sécurité un peu plus tard, au cas où la barre
        // d'adresse change encore une fois après le démarrage.
        setTimeout(recompute, 600);
      }));
    }

    window.addEventListener('load', () => setTimeout(waitStableThenStart, 200));
    window.addEventListener('resize', recompute);
    if (window.visualViewport) {
      window.visualViewport.addEventListener('resize', recompute);
    }
  })();
</script>

